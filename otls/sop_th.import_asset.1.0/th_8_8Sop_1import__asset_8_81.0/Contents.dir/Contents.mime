metadata_python	[ 0	locks=0 ]	(	"import hou

from tumblepipe.pipe.houdini import util

node = hou.pwd()
stage = node.editableStage()
root = stage.GetPseudoRoot()

def update(root):
    prim = root.GetPrimAtPath('/METADATA/asset/CHAR/Snail')
    if not prim.IsValid(): return
    metadata = util.get_metadata(prim)
    
    if metadata is None:
        metadata = {
            'context': 'asset',
            'category': 'CHAR',
            'asset': 'Snail',
            'instance': 'Snail',
            'inputs': []
        }
    
    util.add_metadata_input(metadata, {
        'context': 'asset',
        'category': 'CHAR',
        'asset': 'Snail',
        'department': 'model',
        'version': 'v0005',
    })
    
    util.set_metadata(prim, metadata)
    
update(root)
"	)
