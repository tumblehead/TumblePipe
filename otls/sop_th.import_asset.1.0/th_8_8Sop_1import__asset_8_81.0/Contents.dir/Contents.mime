{
    channel category {
      lefttype = extend
      righttype = extend
      defaultString = \"CHAR\"
      flags = 0
      segment { length = 0 expr = chs(\"../../category\") }
    }
    channel asset {
      lefttype = extend
      righttype = extend
      defaultString = \"Snail\"
      flags = 0
      segment { length = 0 expr = chs(\"../../asset\") }
    }
    channel departments {
      lefttype = extend
      righttype = extend
      defaultString = \"\"
      flags = 0
      segment { length = 0 expr = chs(\"../../departments\") }
    }
    channel include_layerbreak {
      lefttype = extend
      righttype = extend
      default = 1
      flags = 0
      segment { length = 0 value = 1 1 expr = ch(\"../../include_layerbreak\") }
    }
    channel import {
      lefttype = extend
      righttype = extend
      flags = 0
      segment { length = 0 expr = ch(\"../../import\") }
    }
  }

