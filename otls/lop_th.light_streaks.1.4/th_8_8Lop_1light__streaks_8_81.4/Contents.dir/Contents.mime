            label   "Primitive Specifier"
            export  none
        }
        parm {
            name    "parentprimtype"
            baseparm
            label   "Parent Primitive Type"
            export  none
        }
    }

    group {
        name    "Karma"
        label   "Karma"

        groupcollapsible {
            name    "xn__MotionBlur_6ja"
            label   "Motion Blur"
            parmtag { "group_default" "1" }
            grouptag { "group_type" "collapsible" }

