            parmtag { "usdvaluetype" "string" }
        }
        parm {
            name    "triplanar_blend_control"
            label   "triplanar_blend"
            type    string
            default { "none" }
            disablewhen "{ projection != 1 }"
            menujoin {
                [ "import loputils" ]
                [ "return loputils.createEditPropertiesControlMenu(" ]
                [ "           kwargs, 'float', 'inputs:triplanar_blend', True, False)" ]
                language python
            }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "triplanar_blend"
            label   "Tri-Planar Blend"
            type    float
            default { "0.25" }
            disablewhen "{ projection != 1 } { triplanar_blend_control == block } { triplanar_blend_control == none } { triplanar_blend_control == disconnectinput }"
            range   { 0 1 }
            parmtag { "parmvop" "1" }
            parmtag { "usdvaluename" "inputs:triplanar_blend" }
            parmtag { "usdvaluetype" "float" }
        }
        parm {
            name    "triplanar_upaxis_control"
            label   "triplanar_upaxis"
            type    string
            default { "none" }
            disablewhen "{ projection != 1 }"
            menujoin {
                [ "import loputils" ]
                [ "return loputils.createEditPropertiesControlMenu(" ]
                [ "           kwargs, 'float', 'inputs:triplanar_upaxis', True, False)" ]
                language python
            }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "triplanar_upaxis"
            label   "Tri-Planar Up Axis"
            type    integer
            default { "1" }
            disablewhen "{ projection != 1 } { triplanar_upaxis_control == block } { triplanar_upaxis_control == none } { triplanar_upaxis_control == disconnectinput }"
            menu {
                "0" "X"
                "1" "Y"
                "2" "Z"
            }
            range   { 0 10 }
            parmtag { "parmvop" "1" }
            parmtag { "usdvaluename" "inputs:triplanar_upaxis" }
            parmtag { "usdvaluetype" "float" }
        }
    }

    parm {
        name    "displacement_control"
        label   "displacement_control"
        type    string
        invisible
        default { [ "'none' if hou.pwd().evalParm('true_displacements')==1 else 'disconnectinput'" python ] }
        parmtag { "sidefx::shader_isparm" "1" }
        parmtag { "sidefx::shader_makecontrolparm" "0" }
    }
    parm {
        name    "displacement"
        label   "displacement"
        type    string
        invisible
        default { "" }
        parmtag { "sidefx::shader_makecontrolparm" "0" }
        parmtag { "usdisconnection" "1" }
        parmtag { "usdvaluename" "outputs:mtlx:displacement" }
        parmtag { "usdvaluetype" "token" }
    }

