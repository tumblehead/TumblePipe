}


@WRITEBACK
{
    if (@tmask.x==0)
    {
        float a_up = @tmask.bufferIndex(@ixy+(int2)(0, 1))[0];  
        float a_down = @tmask.bufferIndex(@ixy+(int2)(0, -1))[0];  
        float a_left = @tmask.bufferIndex(@ixy+(int2)(1, 0))[0];  
        float a_right = @tmask.bufferIndex(@ixy+(int2)(-1, 0))[0];  
    
        float4 up = @tdst.bufferIndex(@ixy+(int2)(0, 1));  
