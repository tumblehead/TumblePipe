        float4 left = @tdst.bufferIndex(@ixy+(int2)(1, 0));  
        float4 right = @tdst.bufferIndex(@ixy+(int2)(-1, 0));
        
        float4 combined=up*a_up+down*a_down+left*a_left+right*a_right;
        float total=a_up+a_down+a_left+a_right;
        
        if (total!=0.0f)
        {
            @dst.set(combined/total);
            @dstmask.set(1.0);
        }
        else
        {
            @dst.set(0);
            @dstmask.set(0);
        }
    }
    else
