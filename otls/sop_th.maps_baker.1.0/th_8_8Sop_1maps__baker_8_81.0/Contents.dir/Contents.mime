--HOUDINIMIMEBOUNDARY0xD3ADD339-0x00000F49-0x56B122C9-0x00000001HOUDINIMIMEBOUNDARY
Content-Disposition: attachment; filename="hdaroot/bake_maps2/padding/opencl1.parm"
Content-Type: text/plain

{
version 0.8
stdswitcher	[ 0	locks=0 ]	(	0	0	0	0	0	)
kernelcode	[ 0	locks=0 ]	(	"#bind layer src?
#bind layer mask?

#bind layer &tdst
#bind layer &tmask
#bind layer &dst
#bind layer &dstmask

@KERNEL
{
    if (@Iteration==0)
    {
        @tdst.set(@src);
        @tmask.set(@mask);
    }
    else
    {
        if (@dstmask.x==0)
        {
            float a_up = @dstmask.bufferIndex(@ixy+(int2)(0, 1))[0];  
            float a_down = @dstmask.bufferIndex(@ixy+(int2)(0, -1))[0];  
            float a_left = @dstmask.bufferIndex(@ixy+(int2)(1, 0))[0];  
            float a_right = @dstmask.bufferIndex(@ixy+(int2)(-1, 0))[0];  
        
            float4 up = @dst.bufferIndex(@ixy+(int2)(0, 1));  
            float4 down = @dst.bufferIndex(@ixy+(int2)(0, -1));  
            float4 left = @dst.bufferIndex(@ixy+(int2)(1, 0));  
            float4 right = @dst.bufferIndex(@ixy+(int2)(-1, 0));
            
            float4 combined = (
                up * a_up +
                down * a_down +
                left * a_left +
                right * a_right
            );
                
            float total = (
                a_up + 
                a_down + 
                a_left + 
                a_right
            );
            
            if (total!=0.0f)
            {
                @tdst.set(combined/total);
                @tmask.set(1.0);
            }
            else
            {
                @tdst.set(0);
                @tmask.set(0);
            }
        }
        else
        {
            @tdst.set(@dst);
            @tmask.set(@dstmask);
        }
    }
}


@WRITEBACK
{
    if (@tmask.x==0)
    {
        float a_up = @tmask.bufferIndex(@ixy+(int2)(0, 1))[0];  
        float a_down = @tmask.bufferIndex(@ixy+(int2)(0, -1))[0];  
        float a_left = @tmask.bufferIndex(@ixy+(int2)(1, 0))[0];  
        float a_right = @tmask.bufferIndex(@ixy+(int2)(-1, 0))[0];  
    
        float4 up = @tdst.bufferIndex(@ixy+(int2)(0, 1));  
        float4 down = @tdst.bufferIndex(@ixy+(int2)(0, -1));  
        float4 left = @tdst.bufferIndex(@ixy+(int2)(1, 0));  
        float4 right = @tdst.bufferIndex(@ixy+(int2)(-1, 0));
        
        float4 combined=up*a_up+down*a_down+left*a_left+right*a_right;
        float total=a_up+a_down+a_left+a_right;
        
        if (total!=0.0f)
        {
            @dst.set(combined/total);
            @dstmask.set(1.0);
        }
        else
        {
            @dst.set(0);
            @dstmask.set(0);
        }
    }
    else
    {
        @dst.set(@tdst);
        @dstmask.set(@tmask);
    }
}




"	)
kerneloptions	[ 0	locks=0 ]	(	""	)
options_tile	[ 0	locks=0 ]	(	1	1	)
options_iterations	[ 0	locks=0 ]	(	6	)
options_iteration	[ 0	locks=0 ]	(	"on"	)
