Content-Type: text/plain

{
    channel videoframestart {
      lefttype = extend
      righttype = extend
      flags = 0
      segment { length = 0 expr = $FSTART }
    }
    channel videoframe {
      lefttype = extend
      righttype = extend
      flags = 0
      segment { length = 0 expr = $F }
    }
    channel reload {
      lefttype = extend
      righttype = extend
      flags = 0
      segment { length = 0 expr = ch(\"../../reload\") }
    }
    channel filename {
      lefttype = extend
      righttype = extend
      defaultString = \"C:/Users/tumblehead/Desktop/images/testing.psd\"
      flags = 0
      segment { length = 0 expr = "hda = hou.pwd().node(\"../..\")
image_save_path = hda.evalParm(\"image_save_path\")
image_name = hda.evalParm(\"image_name\")

return f\"{image_save_path}/{image_name}.psd\"" language = python }
    }
  }

