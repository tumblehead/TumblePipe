psd_template = r"W:\_pipeline\pipeline\krita\blank_template.psd"
file_cop = hou.pwd().node('copnet/editor_file')

def open_location():
    image_path = hou.expandString(hou.evalParm("image_save_path"))
    os.startfile(image_path)
    
def get_image_paths():
    """Get the image name and full path for the current node."""
    node = hou.pwd()
    
    try:
        referenced_file = node.node('copnet/editor_file').evalParm('filename')
        image_name = node.evalParm("image_name")
        image_save_path = node.evalParm("image_save_path")
        IMAGE_PATH = f"{image_save_path}/{image_name}.psd"
        return referenced_file, IMAGE_PATH, image_name
    except Exception as e:
        hou.ui.displayMessage(f"Error getting image path: {e}")
        return None, None, None

def file_exists(image: str) -> bool:
    """Check if image file exists."""
    return bool(image) and Path(image).exists()

def create_krita_file(destination: str):
    try:
        Path(destination).parent.mkdir(parents=True, exist_ok=True)
        
        resolution = hou.pwd().evalParmTuple("image_resolution")
        width = int(resolution[0])
        height = int(resolution[1])

        copied_file = shutil.copy(psd_template, destination)
        
        return True
    except Exception as e:
        hou.ui.displayMessage(f"Failed to create PSD file: {e}")
        return False        
        
def open_krita(image: str) -> None:
    """Open image in Krita."""
    try:
        # Get editor path at runtime, not at module load
        editor_exe = hou.pwd().evalParm("editor")
        subprocess.Popen([editor_exe, image])
    except Exception as e:
        hou.ui.displayMessage(f"Failed to open editor: {e}")

def reference_image(image_path: str) -> None:
    """Set the image path in the COP file node."""
    node = hou.pwd()
    image_node = node.node('copnet/editor_file')
    
    if image_node:
        image_node.parm("filename").set(image_path)
    else:
        hou.ui.displayMessage("Could not find copnet/editor_file node")

def reload_file_node_aovs():
    file_cop.parm("reload").pressButton()
    file_cop.parm("aovs").set(0)
    file_cop.parm("addaovs").pressButton()
    for output_node in file_cop.outputs():
        output_node.destroy()
    
def create_null_outputs(node: hou.Node) -> list[hou.Node]:
    created_nodes = list()
    for i, output in enumerate(node.outputNames()):
        null = network.createNode("null", output)
        null.setInput(0, selection, i)
        created_nodes.append(null)
