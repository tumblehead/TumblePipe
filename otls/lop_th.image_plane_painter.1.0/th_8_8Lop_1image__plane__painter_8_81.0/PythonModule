def main():
    referenced_file, IMAGE_PATH, image_name = get_image_paths()
    
    # Exit if we couldn't get the paths
    if IMAGE_PATH is None:
        return
    
    if file_exists(referenced_file):
        # File exists, just open it
        open_krita(referenced_file)
    else:
        # Create new PSD file at specified resolution
        if create_krita_file(IMAGE_PATH):
            # Open in editor
            open_krita(IMAGE_PATH)
            
def thumbnail():
    desktop = hou.ui.curDesktop()
    editor = desktop.paneTabOfType(hou.paneTabType.NetworkEditor)
    thumbnail_path = f"{hou.pwd().evalParm('image_save_path')}/{hou.pwd().evalParm('image_name')}.psd"
    
    # GET ALL IMAGES
    images = list(editor.backgroundImages())
    
    # REMOVE ATTACHED THUMBNAIL
    images = [img for img in images if img.relativeToPath() != hou.pwd().path()]
    editor.setBackgroundImages(images)
    
    # CREATE NEW THUMBNAIL
    image = hou.NetworkImage(thumbnail_path, hou.BoundingRect(-4, -1.25, 1, 1))
    image.setRelativeToPath(hou.pwd().path())

    images.append(image)

    # APPLY AND SAVE BACKGROUND IMAGES
    editor.setBackgroundImages(images)
    nodegraphutils.saveBackgroundImages(editor.pwd(), editor.backgroundImages())
    nodegraphutils.loadBackgroundImages(editor.pwd())