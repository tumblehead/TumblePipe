--HOUDINIMIMEBOUNDARY0xD3ADD339-0x00000F49-0x56B122C9-0x00000001HOUDINIMIMEBOUNDARY
Content-Disposition: attachment; filename="hdaroot/update_lpe_aovs/loop_tags_end.chn"
Content-Type: text/plain

{
    channel strings {
      lefttype = extend
      righttype = extend
      defaultString = \"\"
      flags = 0
      start = 41.666666666666664
      segment { length = 0 expr = "from pxr import UsdGeom

from tumblepipe.pipe.houdini import util

def _flatten(xss):
    return { x for xs in xss for x in xs }

def _light_tags(light_prim):
    
    def _is_lpe_tag_prop(prop):
        prop_name = prop.GetName()
        return prop_name.endswith('karma:light:lpetag')

    if UsdGeom.Imageable(light_prim).ComputeVisibility() == \"invisible\": return []
    tag_props = [
        prop for prop in light_prim.GetProperties()
        if _is_lpe_tag_prop(prop)
    ]
    tag_names = list()
    for tag_prop in tag_props:
        if not tag_prop.IsValid(): continue
        tag_name = (
            tag_prop.Get(1001)
            if tag_prop.GetNumTimeSamples() else
            tag_prop.Get()
        )
        if tag_name is None: continue
        if tag_name == 'Untagged_Lights': continue
        if tag_name in tag_names: continue
        tag_names.append(tag_name)
    return tag_names

node = hou.node('../IN_stage')
root = node.stage().GetPseudoRoot()
tag_names = _flatten([
    _light_tags(root.GetPrimAtPath(light_path))
    for light_path in util.list_lights(root)
])
return ' '.join(tag_names)" language = python }
    }
  }

