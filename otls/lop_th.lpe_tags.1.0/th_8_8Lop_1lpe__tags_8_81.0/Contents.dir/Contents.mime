--HOUDINIMIMEBOUNDARY0xD3ADD339-0x00000F49-0x56B122C9-0x00000001HOUDINIMIMEBOUNDARY
Content-Disposition: attachment; filename="hdaroot/update_lpe_aovs/specular.spareparmdef"
Content-Type: text/plain

    parm {
        name    "should_split"
        label   "Should Split"
        type    toggle
        default { "0" }
        help    "Refer to this in expressions as -1, such as: npoints(-1)"
        parmtag { "cook_dependent" "1" }
        parmtag { "opfilter" "!!SOP!!" }
        parmtag { "oprelative" "." }
    }
    parm {
        name    "aov_name"
        label   "AOV Name"
        type    string
        default { "$OS" }
        parmtag { "script_callback_language" "python" }
    }
    parm {
        name    "tag_name"
        label   "Tag Name"
        type    string
        default { "" }
        parmtag { "script_callback_language" "python" }
    }

--HOUDINIMIMEBOUNDARY0xD3ADD339-0x00000F49-0x56B122C9-0x00000001HOUDINIMIMEBOUNDARY
Content-Disposition: attachment; filename="hdaroot/update_lpe_aovs/specular.chn"
Content-Type: text/plain

{
    channel tag_name {
      lefttype = extend
      righttype = extend
      defaultString = \"\"
      flags = 0
      start = 41.666666666666664
      segment { length = 0 expr = @TAG }
    }
    channel should_split {
      lefttype = extend
      righttype = extend
      flags = 0
      start = 41.666666666666664
      segment { length = 0 expr = "aov_name = hou.pwd().parm('aov_name').eval()
aov_names = hou.node('../IN_stage').parm('aov_names').eval().split(' ')
return aov_name in aov_names" language = python }
    }
  }

