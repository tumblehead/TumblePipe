    channel tag_name {
      lefttype = extend
      righttype = extend
      defaultString = \"\"
      flags = 0
      start = 41.666666666666664
      segment { length = 0 expr = @TAG }
    }
    channel should_split {
      lefttype = extend
      righttype = extend
      flags = 0
      start = 41.666666666666664
      segment { length = 0 expr = "aov_name = hou.pwd().parm('aov_name').eval()
aov_names = hou.node('../IN_stage').parm('aov_names').eval().split(' ')
return aov_name in aov_names" language = python }
    }
  }

