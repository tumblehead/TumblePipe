--HOUDINIMIMEBOUNDARY0xD3ADD339-0x00000F49-0x56B122C9-0x00000001HOUDINIMIMEBOUNDARY
Content-Disposition: attachment; filename="hdaroot/update_denoiser_settings.chn"
Content-Type: text/plain

{
    channel sample_f1 {
      lefttype = extend
      righttype = extend
      default = 1
      flags = 0
      start = 41.666666666666664
      segment { length = 0 value = 1 1 expr = @fstart }
    }
    channel sample_f2 {
      lefttype = extend
      righttype = extend
      default = 240
      flags = 0
      start = 41.666666666666664
      segment { length = 0 value = 240 240 expr = @fend }
    }
    channel sample_f3 {
      lefttype = extend
      righttype = extend
      default = 1
      flags = 0
      start = 41.666666666666664
      segment { length = 0 value = 1 1 expr = @finc }
    }
    channel errormsg {
      lefttype = extend
      righttype = extend
      defaultString = \"\"
      flags = 0
      start = 41.666666666666664
      segment { length = 0 expr = __import__('loputils').renderProductAndSettingsErrorMessage() language = python }
    }
    channel resolution2 {
      lefttype = extend
      righttype = extend
      default = 1080
      flags = 0
      segment { options = {	 untie  iv ov is os ia oa }

	 length = 0 expr = "pythonexprf(\"__import__('loputils').computeResolutionParameter(True, False)\")" }
    }
    channel xn__karmaglobalimagefilter_vcbg {
      lefttype = extend
      righttype = extend
      defaultString = \"\"
      flags = 0
      start = 41.666666666666664
      segment { length = 0 expr = "import json
import hou

# Helpers
def _is_additional_render_var(render_var_prim):
    name = render_var_prim.GetName().lower()
    if name == 'albedo': return False
    if name == 'normal': return False
    return True

def _get_aov_name(render_var_prim):
    name_attribute = render_var_prim.GetAttribute('driver:parameters:aov:name')
    return name_attribute.Get()
    
# Get ready to scan and update
node = hou.pwd()
stage = node.inputs()[0].stage()
root = stage.GetPseudoRoot()

# Find additional render products that need denoising
render_vars_prim = root.GetPrimAtPath('/Render/Products/Vars')
additional_render_vars = list()
if render_vars_prim.IsValid():
    additional_render_vars.extend([
        _get_aov_name(render_var_prim)
        for render_var_prim in render_vars_prim.GetChildren()
        if _is_additional_render_var(render_var_prim)
    ])

# Update the OIDN denoiser settings
return json.dumps([[
    \"denoise\",
    {
        \"engine\": \"oidn\",
        \"use_n_input\": True,
        \"use_albedo_input\": True,
        \"aovs\": additional_render_vars
    }
]])" language = python }
    }
  }

--HOUDINIMIMEBOUNDARY0xD3ADD339-0x00000F49-0x56B122C9-0x00000001HOUDINIMIMEBOUNDARY
