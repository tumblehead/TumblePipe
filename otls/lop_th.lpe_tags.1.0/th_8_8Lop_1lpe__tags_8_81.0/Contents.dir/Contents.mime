    parm {
        name    "should_split"
        label   "Should Split"
        type    toggle
        default { "0" }
        help    "Refer to this in expressions as -1, such as: npoints(-1)"
        parmtag { "cook_dependent" "1" }
        parmtag { "opfilter" "!!SOP!!" }
        parmtag { "oprelative" "." }
    }
    parm {
        name    "aov_name"
        label   "AOV Name"
        type    string
        default { "$OS" }
        parmtag { "script_callback_language" "python" }
    }
