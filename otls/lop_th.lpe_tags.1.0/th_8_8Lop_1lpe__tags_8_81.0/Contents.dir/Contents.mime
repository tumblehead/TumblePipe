Content-Type: text/plain

comment ""
position 3.07878 7.78661
connectornextid 2
flags =  lock off model off template off footprint off xray off bypass off display off render on highlight off unload off savedata off compress on colordefault on exposed on debug off
outputsNamed3
{
1 "output1"
}
inputsNamed3
{
0 	IN_stage 1 1 "input1"
}
inputs
{
0 	IN_stage 0 1
}
stat
{
  create -1
  modify -1
  author Tumblehead@judas-3070
  access 0777
}
color UT_Color RGB 0.8 0.8 0.8 
delscript ""
exprlanguage hscript
end

