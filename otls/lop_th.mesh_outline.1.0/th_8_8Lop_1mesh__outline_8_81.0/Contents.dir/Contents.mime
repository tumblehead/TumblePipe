{
    channel attribpainted1 {
      lefttype = extend
      righttype = extend
      flags = 0
      start = 41.666666666666664
      segment { length = 0 expr = "phm().isattribpainted(pwd(), pwd().parm( expandString('$CH') ).multiParmInstanceIndices()[0])" language = python }
    }
    channel stroke_attrib {
      lefttype = extend
      righttype = extend
      defaultString = \"line_thickness\"
      flags = 0
      start = 41.666666666666664
      segment { length = 0 expr = chs(\"../../../../stroke_attrib\") }
    }
    channel stroke_attribtype {
      lefttype = extend
      righttype = extend
      default = 1
      flags = 0
      start = 41.666666666666664
      segment { length = 0 value = 1 1 expr = ch(\"../../../../stroke_attribtype\") }
    }
