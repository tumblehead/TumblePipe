--HOUDINIMIMEBOUNDARY0xD3ADD339-0x00000F49-0x56B122C9-0x00000001HOUDINIMIMEBOUNDARY
Content-Disposition: attachment; filename="hdaroot/outline_material/outline_mtl/triplanarprojection.chn"
Content-Type: text/plain

{
    channel filex {
      lefttype = extend
      righttype = extend
      defaultString = \"op:/stage/mesh_outline1/copnet/OUT_TEXTURE\"
      flags = 0
      start = 41.666666666666664
      segment { length = 0 expr = "node = hou.pwd()
hda = node.node(\"../../..\")
texture_mode = hda.evalParm(\"texture_mode\")
cop_texture_output = hda.node(\"copnet/OUT_TEXTURE\")
cop_expression = f\"op:{cop_texture_output.path()}\"
if texture_mode == 1:
    return cop_expression
elif texture_mode == 2:
    return hda.evalParm(\"filex\")" language = python }
    }
  }

