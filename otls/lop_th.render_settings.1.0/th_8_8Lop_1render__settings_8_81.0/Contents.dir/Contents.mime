return xform.extractRotates()[0]" language = python }
    }
    channel lookatprimroty {
      lefttype = extend
      righttype = extend
      flags = 0
      segment { length = 0 expr = "import loputils
from pxr import Usd, UsdGeom

lop_node = hou.node('.')
path = lop_node.evalParm('lookatprim')
if not path:
    return 0

stage = lop_node.stage()
