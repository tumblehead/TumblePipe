--HOUDINIMIMEBOUNDARY0xD3ADD339-0x00000F49-0x56B122C9-0x00000001HOUDINIMIMEBOUNDARY
Content-Disposition: attachment; filename="hdaroot/matte_mat.spareparmdef"
Content-Type: text/plain

    groupcollapsible {
        name    "sample_group2"
        label   "Frame Range/Subframes"
        grouptag { "group_type" "collapsible" }
        parmtag { "sidefx::header_parm" "sample_behavior" }
        grouptag { "sidefx::switcher" "sample_group" }

        parm {
            name    "sample_behavior"
            baseparm
            label   "Sampling Behavior"
            export  none
        }
        parm {
            name    "sample_f"
            baseparm
            label   "Start/End/Inc"
            export  none
        }
        parm {
            name    "sample_subframeenable"
            baseparm
            label   "Subframe Sampling"
            export  none
        }
        groupsimple {
            name    "sample_subframegroup2"
            label   "Subframe Sampling"
            disablewhen "{ sample_subframeenable == 0 }"
            grouptag { "group_type" "simple" }
            parmtag { "sidefx::header_toggle" "sample_subframeenable" }
            grouptag { "sidefx::switcher" "sample_subframegroup" }

            parm {
                name    "sample_shuttermode"
                baseparm
                label   "Shutter"
                export  none
            }
            parm {
                name    "sample_shutterrange"
                baseparm
                label   "Shutter Open/Close"
                export  none
            }
            parm {
                name    "sample_cameraprim"
                baseparm
                label   "Camera Prim"
                export  none
            }
            parm {
                name    "sample_count"
                baseparm
                label   "Samples"
                export  none
            }
            parm {
                name    "sample_includeframe"
                baseparm
                label   "Always Include Frame Sample"
                export  none
            }
        }

    }

    parm {
        name    "primpath"
        baseparm
        label   "Primitive Path"
        export  none
    }
    parm {
        name    "classprimpath"
        baseparm
        label   "Class Prim Path"
        export  none
    }
    groupcollapsible {
        name    "folder0"
        label   "Quick Material"
        grouptag { "group_type" "collapsible" }
        parmtag { "sidefx::header_parm" "quickmaterialrefresh" }

        parm {
            name    "quickmaterialrefresh"
            label   "Refresh"
            type    button
            default { "0" }
            parmtag { "script_callback" "hou.pwd().parm('reload').pressButton;hou.pwd().parm('createparms').pressButton()" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "reftype"
            baseparm
            label   "Reference Type"
            export  none
        }
        parm {
            name    "classancestor"
            baseparm
            label   "Class Ancestor"
            export  none
        }
        parm {
            name    "reffilepath"
            baseparm
            label   "Reference File Path"
            export  none
        }
        parm {
            name    "reload"
            baseparm
            label   "Reload File"
            export  none
        }
        parm {
            name    "createparms"
            baseparm
            label   "Create Parameters"
            export  none
        }
        parm {
            name    "createoutputparms"
            baseparm
            label   "Create Material Outputs"
            export  none
        }
        parm {
            name    "primpattern"
            baseparm
            label   "Primitives"
            export  none
        }
        parm {
            name    "initforedit"
            baseparm
            label   "Initialize Parameters"
            export  none
        }
        groupsimple {
            name    "destinationprim_group2"
            label   "Destination Primitive"
            hidewhen "{ reftype == none } { reftype == createclass }"
            grouptag { "group_type" "simple" }
            grouptag { "sidefx::switcher" "destinationprim_group" }

            parm {
                name    "refparentmat"
                baseparm
                label   "Reference Parent Material"
                export  none
            }
            parm {
                name    "instanceable"
                baseparm
                label   "Make Instanceable"
                export  none
            }
            parm {
                name    "parentprimtype"
                baseparm
                label   "Parent Primitive Type"
                export  none
            }
        }

    }

    parm {
        name    "primtype"
        baseparm
        label   "Primitive Type"
        export  none
    }
    groupcollapsible {
        name    "folder0_0"
        label   "Base"
        parmtag { "group_default" "1" }
        grouptag { "group_type" "collapsible" }
        grouptag { "sidefx::shader_isparm" "0" }

        parm {
            name    "base_control"
            label   "base"
            type    string
            default { "none" }
            menujoin {
                [ "import loputils" ]
                [ "return loputils.createEditPropertiesControlMenu(" ]
                [ "           kwargs, 'float', 'inputs:base', True, False)" ]
                language python
            }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "base"
            label   "Base"
            type    float
            default { "1" }
            disablewhen "{ base_control == block } { base_control == none } { base_control == disconnectinput }"
            range   { 0 1 }
            parmtag { "ogl_diff_intensity" "1" }
            parmtag { "parmvop" "1" }
            parmtag { "usdvaluename" "inputs:base" }
            parmtag { "usdvaluetype" "float" }
        }
        parm {
            name    "base_color_control"
            label   "base_color"
            type    string
            default { "none" }
            menujoin {
                [ "import loputils" ]
                [ "return loputils.createEditPropertiesControlMenu(" ]
                [ "           kwargs, 'color3f', 'inputs:base_color', True, False)" ]
                language python
            }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "base_color"
            label   "Color"
            type    color
            size    3
            default { "1" "1" "1" }
            disablewhen "{ base_color_control == block } { base_color_control == none } { base_color_control == disconnectinput }"
            range   { 0 1 }
            parmtag { "ogl_diff" "1" }
            parmtag { "parmvop" "1" }
            parmtag { "usdvaluename" "inputs:base_color" }
            parmtag { "usdvaluetype" "color3f" }
        }
        parm {
            name    "base_color_file_control"
            label   "base_color_file"
            type    string
            default { "none" }
            menujoin {
                [ "import loputils" ]
                [ "return loputils.createEditPropertiesControlMenu(" ]
                [ "           kwargs, 'asset', 'inputs:base_color_file', True, False)" ]
                language python
            }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "base_color_file"
            label   "Color Map"
            type    image
            default { "" }
            disablewhen "{ base_color_file_control == block } { base_color_file_control == none } { base_color_file_control == disconnectinput }"
            parmtag { "parmvop" "1" }
