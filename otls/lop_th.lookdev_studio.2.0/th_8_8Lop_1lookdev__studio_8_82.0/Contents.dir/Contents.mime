                default { "none" }
                menujoin {
                    [ "import loputils" ]
                    [ "return loputils.createEditPropertiesControlMenu(kwargs, 'float')" ]
                    language python
                }
                parmtag { "sidefx::look" "icon" }
            }
            parm {
                name    "xn__karmalightspread_31af"
                label   "Spread"
                type    float
                default { "1" }
                disablewhen "{ xn__karmalightspread_control_4fbf == block } { xn__karmalightspread_control_4fbf == none }"
