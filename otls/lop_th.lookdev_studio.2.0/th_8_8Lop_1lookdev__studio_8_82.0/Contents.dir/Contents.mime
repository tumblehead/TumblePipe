--HOUDINIMIMEBOUNDARY0xD3ADD339-0x00000F49-0x56B122C9-0x00000001HOUDINIMIMEBOUNDARY
Content-Disposition: attachment; filename="hdaroot/camera_lookat_asset.spareparmdef"
Content-Type: text/plain

    groupcollapsible {
        name    "spare_util_parms"
        label   "Spare Util Parms"

        parm {
            name    "lop_activation"
            label   "Activation"
            type    toggle
            default { "1" }
        }
    }

    groupcollapsible {
        name    "sample_group2"
        label   "Frame Range/Subframes"
        grouptag { "group_type" "collapsible" }
        grouptag { "group_type:0" "collapsible" }
        parmtag { "sidefx::header_parm" "sample_behavior" }
        grouptag { "sidefx::switcher" "sample_group" }
        grouptag { "sidefx::switcher:0" "sample_group" }

        parm {
            name    "sample_behavior"
            baseparm
            label   "Sampling Behavior"
            export  none
        }
        parm {
            name    "sample_f"
            baseparm
            label   "Start/End/Inc"
            export  none
        }
        parm {
            name    "sample_subframeenable"
            baseparm
            label   "Subframe Sampling"
            export  none
        }
        groupsimple {
            name    "sample_subframegroup2"
            label   "Subframe Sampling"
            disablewhen "{ sample_subframeenable == 0 }"
            grouptag { "group_type" "simple" }
            grouptag { "group_type:0" "simple" }
            parmtag { "sidefx::header_toggle" "sample_subframeenable" }
            grouptag { "sidefx::switcher" "sample_subframegroup" }
            grouptag { "sidefx::switcher:0" "sample_subframegroup" }

            parm {
                name    "sample_shuttermode"
                baseparm
                label   "Shutter"
                export  none
            }
            parm {
                name    "sample_shutterrange"
                baseparm
                label   "Shutter Open/Close"
                export  none
            }
            parm {
                name    "sample_cameraprim"
                baseparm
                label   "Camera Prim"
                export  none
            }
            parm {
                name    "sample_count"
                baseparm
                label   "Samples"
                export  none
            }
            parm {
                name    "sample_includeframe"
                baseparm
                label   "Always Include Frame Sample"
                export  none
            }
        }

    }

    groupsimple {
        name    "folder3"
        label   "Source"
        grouptag { "group_type" "simple" }

        parm {
            name    "sourcetype"
            baseparm
            label   "Type"
            export  none
        }
        parm {
            name    "source"
            baseparm
            label   "Source"
            export  none
        }
        parm {
            name    "sourceinstances"
            baseparm
            label   "Source Instances"
            export  none
        }
    }

    groupsimple {
        name    "folder4"
        label   "Look At"
        grouptag { "group_type" "simple" }

        parm {
            name    "targetsource"
            baseparm
            label   "Target Source"
            export  none
        }
        parm {
            name    "targettype"
            baseparm
            label   "Type"
            export  none
        }
        parm {
            name    "target"
            baseparm
            label   "Target"
            export  none
        }
        parm {
            name    "targetinstance"
            baseparm
            label   "Target Instance"
            export  none
        }
        parm {
            name    "targetpos"
            baseparm
            label   "Target Position"
            export  none
        }
        parm {
            name    "hidetarget"
            baseparm
            label   "Hide Target"
            export  none
        }
        parm {
            name    "importtime"
            baseparm
            label   "Import Time"
            export  none
        }
    }

    groupsimple {
        name    "folder5"
        label   "Orientation"
        grouptag { "group_type" "simple" }

        parm {
            name    "lookataxis"
            baseparm
            label   "Look At Axis"
            export  all
        }
        parm {
            name    "lookupaxisx"
            baseparm
            label   "Look Up Axis"
            export  all
        }
        parm {
            name    "lookupaxisy"
            baseparm
            label   "Look Up Axis"
            export  all
        }
        parm {
            name    "lookupaxisz"
            baseparm
            label   "Look Up Axis"
            export  all
        }
        parm {
            name    "up"
            baseparm
            label   "Up Vector"
            export  none
        }
        parm {
            name    "upvectorsource"
            baseparm
            label   "Up Vector Source"
            export  none
        }
        parm {
            name    "upvectorxform"
            baseparm
            label   "Up Vector Xform"
            export  none
        }
        parm {
            name    "upvector"
            baseparm
            label   "Up Vector"
            export  none
        }
        parm {
            name    "twist"
            baseparm
            label   "Twist"
            export  all
        }
    }


