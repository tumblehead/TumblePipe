--HOUDINIMIMEBOUNDARY0xD3ADD339-0x00000F49-0x56B122C9-0x00000001HOUDINIMIMEBOUNDARY
Content-Disposition: attachment; filename="hdaroot/light_render_switch.chn"
Content-Type: text/plain

{
    channel input {
      lefttype = extend
      righttype = extend
      flags = 0
      segment { length = 0 expr = "hda = hou.pwd().node('..')
start_frame: int = hda.evalParm(\"asset_turn_framerangemin\")
end_frame: int = hda.evalParm(\"light_turn_framerangemax\")+1
frame_range: int = end_frame - start_frame

return int((hou.frame()-start_frame)/frame_range)" language = python }
    }
  }

