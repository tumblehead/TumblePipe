--HOUDINIMIMEBOUNDARY0xD3ADD339-0x00000F49-0x56B122C9-0x00000001HOUDINIMIMEBOUNDARY
Content-Disposition: attachment; filename="hdaroot/create_framed_camera.parm"
Content-Type: text/plain

{
version 0.8
python	[ 0	locks=0 ]	(	"from husd import assetutils
from pxr import Usd, Gf, UsdGeom

node = hou.pwd()
stage = node.editableStage()

# CREATE FRAMED CAMERA FOR BOUNDING BOX
prim = stage.GetPrimAtPath(\"/ASSET\")
bbox_cache = UsdGeom.BBoxCache(Usd.TimeCode.EarliestTime(), ['default', 'render'])
bounds = bbox_cache.ComputeLocalBound(prim).GetBox()
camera_prim = assetutils.createFramedCameraToBounds(stage, bounds, rotatex=0, rotatey=0, offsetdistance=0, cameraprimpath=\"/cameras/turntable_camera\")

# GET Z POSITION
xform = UsdGeom.Xformable(camera_prim)
translate_op = xform.GetOrderedXformOps()[0]
z_pos = translate_op.GetOpTransform(Usd.TimeCode(1001)).ExtractTranslation()[2]

min_point = bounds.GetMin()  # Gf.Vec3d(x_min, y_min, z_min)
max_point = bounds.GetMax()

height = height = max_point[1] - min_point[1]

# SET ZDIST SPARE PARM
node.node(\"..\").parm(\"frame_z_dist\").set(z_pos)
node.node(\"..\").parm(\"bounding_height\").set(height)

"	)
maintainstate	[ 0	locks=0 ]	(	"on"	)
zdist	[ 0	locks=0 ]	(	8.877500429581852	)
}

