    return 0

xform = loputils.getPrimXform(lop_node, path, False)

return xform.extractTranslates()[2]
" language = python }
    }
    channel lookatprimrotx {
      lefttype = extend
      righttype = extend
      flags = 0
      start = 41.666666666666664
      segment { length = 0 expr = "import loputils
