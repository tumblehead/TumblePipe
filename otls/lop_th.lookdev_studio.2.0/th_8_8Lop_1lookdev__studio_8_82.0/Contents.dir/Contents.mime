        label   "Transmission"
        grouptag { "group_type" "collapsible" }

        parm {
            name    "transmission_control"
            label   "transmission"
            type    string
            default { "none" }
            menujoin {
                [ "import loputils" ]
                [ "return loputils.createEditPropertiesControlMenu(" ]
                [ "           kwargs, 'float', 'inputs:transmission', True, False)" ]
                language python
            }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "transmission"
            label   "Transmission"
            type    float
            default { "0" }
            disablewhen "{ transmission_control == block } { transmission_control == none } { transmission_control == disconnectinput }"
            range   { 0 1 }
            parmtag { "ogl_transparency" "1" }
            parmtag { "parmvop" "1" }
            parmtag { "usdvaluename" "inputs:transmission" }
            parmtag { "usdvaluetype" "float" }
