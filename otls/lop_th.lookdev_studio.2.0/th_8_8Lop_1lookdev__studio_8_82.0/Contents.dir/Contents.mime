0 	sphere2 1 1 "input1"
}
inputs
{
0 	sphere2 0 1
}
stat
{
  create -1
  modify -1
  author TH2402@abraham-4090
  access 0777
}
color UT_Color RGB 0.8 0.8 0.8 
creator doc:/solaris/quick_materials#quick_surface_material
explicit 1
delscript ""
exprlanguage hscript
end

