                language python
            }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "filtertype"
            label   "Image Filter Type"
            type    string
            default { "linear" }
            disablewhen "{ filtertype_control == block } { filtertype_control == none } { filtertype_control == disconnectinput }"
            menu {
                "closest"   "closest"
                "linear"    "linear"
                "cubic"     "cubic"
            }
            parmtag { "parmvop" "1" }
            parmtag { "usdvaluename" "inputs:filtertype" }
            parmtag { "usdvaluetype" "string" }
        }
        parm {
