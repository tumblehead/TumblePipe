--HOUDINIMIMEBOUNDARY0xD3ADD339-0x00000F49-0x56B122C9-0x00000001HOUDINIMIMEBOUNDARY
Content-Disposition: attachment; filename="hdaroot/set_bg_size.chn"
Content-Type: text/plain

{
    channel sample_f1 {
      lefttype = extend
      righttype = extend
      flags = 0
      start = 41.666666666666664
      segment { length = 0 expr = @fstart }
    }
    channel sample_f2 {
      lefttype = extend
      righttype = extend
      flags = 0
      start = 41.666666666666664
      segment { length = 0 expr = @fend }
    }
    channel sample_f3 {
      lefttype = extend
      righttype = extend
      flags = 0
      start = 41.666666666666664
      segment { length = 0 expr = @finc }
    }
    channel doscale {
      lefttype = extend
      righttype = extend
      flags = 0
      start = 41.666666666666664
      segment { length = 0 expr = "hda = hou.pwd().node('..')

# Get the button strip parameter value (an integer)
btn_strip_value = hda.evalParm('scale_elements')

# Define how many buttons exist in the strip
num_buttons = 5  # Adjust based on your button strip setup

# Check which buttons are toggled
toggled_buttons = [i for i in range(num_buttons) if (btn_strip_value & (1 << i))]

if 4 in toggled_buttons:
    return 1
else:
    return 0" language = python }
    }
    channel offset_z {
      lefttype = extend
      righttype = extend
      flags = 0
      start = 41.666666666666664
      segment { length = 0 expr = (-ch(\"../frame_z_dist\")*1.3)+ch(\"../bg_dist\") }
    }
  }

