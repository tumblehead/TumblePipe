Content-Disposition: attachment; filename="hdaroot/foreach_input_shot1.chn"
Content-Type: text/plain

{
    channel strings {
      lefttype = extend
      righttype = extend
      defaultString = "\"node = hou.pwd()
hda = node.node(\\\"..\\\")

input_nodes = hda.inputs()
print(input_nodes)\""
      flags = 0
      start = 41.666666666666664
      segment { length = 0 expr = "node = hou.pwd()
hda = node.node(\"..\")

input_nodes = [input.path() for input in hda.inputs()]
input_string = \" \".join(input_nodes)
return input_string" language = python }
    }
    channel firstiteration {
      lefttype = extend
      righttype = extend
      default = 3
      flags = 0
      start = 41.666666666666664
      segment { length = 0 expr = "node = hou.pwd()
frame = hou.frame()
shot_seq = hou.node(\"../\")
num_shots = shot_seq.evalParm(\"shots\")

iteration = 0
for i in range(1, num_shots + 1):
    start = shot_seq.evalParm(f\"startframe{i}\") + shot_seq.evalParm(\"seq_startframe\")
    if frame >= start:
        iteration = i - 1  # zero-based iteration
    else:
        break

return iteration" language = python }
    }
  }

