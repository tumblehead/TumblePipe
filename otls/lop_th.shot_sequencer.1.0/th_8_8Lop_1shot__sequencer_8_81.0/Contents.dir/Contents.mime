--HOUDINIMIMEBOUNDARY0xD3ADD339-0x00000F49-0x56B122C9-0x00000001HOUDINIMIMEBOUNDARY
Content-Disposition: attachment; filename="hdaroot/set_stage_framerange.chn"
Content-Type: text/plain

{
    channel starttime {
      lefttype = extend
      righttype = extend
      default = 1
      flags = 0
      start = 43.75
      segment { length = 0 value = 1 1 expr = ch(\"../seq_startframe\") }
    }
    channel endtime {
      lefttype = extend
      righttype = extend
      flags = 0
      start = 43.75
      segment { length = 0 value = 1100 1100 expr = "node = hou.pwd()
hda = node.node(\"..\")

input_shots = hda.evalParm(\"shots\")
last_shot_length = hda.evalParm(f\"shotlength{input_shots}\")
last_shot_start = hda.evalParm(f\"startframe{input_shots}\")
last_shot_end = last_shot_start + last_shot_length

total_length = 0
for i in range(1, input_shots+1):
    length = hda.evalParm(f\"shotlength{i}\")
    total_length += length

return hda.evalParm(\"seq_startframe\") + total_length" language = python }
    }
    channel timepersecond {
      lefttype = extend
      righttype = extend
      default = 24
      flags = 0
      start = 43.75
      segment { length = 0 value = 24 24 expr = $FPS }
    }
    channel framespersecond {
      lefttype = extend
      righttype = extend
      default = 24
      flags = 0
      start = 43.75
      segment { length = 0 value = 24 24 expr = $FPS }
    }
  }

