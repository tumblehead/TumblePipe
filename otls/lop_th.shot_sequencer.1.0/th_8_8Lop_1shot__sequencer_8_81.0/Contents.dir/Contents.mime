Content-Disposition: attachment; filename="hdaroot/foreach_input_shot.chn"
Content-Type: text/plain

{
    channel strings {
      lefttype = extend
      righttype = extend
      defaultString = "\"node = hou.pwd()
hda = node.node(\\\"..\\\")

input_nodes = hda.inputs()
print(input_nodes)\""
      flags = 0
      start = 41.666666666666664
      segment { length = 0 expr = "node = hou.pwd()
hda = node.node(\"..\")

input_nodes = [input.path() for input in hda.inputs()]
input_string = \" \".join(input_nodes)
return input_string" language = python }
    }
    channel firstiteration {
      lefttype = extend
      righttype = extend
      default = 1
      flags = 0
      start = 41.666666666666664
      segment { length = 0 expr = @shot }
    }
  }

