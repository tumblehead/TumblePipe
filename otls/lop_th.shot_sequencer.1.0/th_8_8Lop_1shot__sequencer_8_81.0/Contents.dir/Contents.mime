Content-Disposition: attachment; filename="hdaroot/shotblock.chn"
Content-Type: text/plain

{
    channel tboptionrange11 {
      lefttype = extend
      righttype = extend
      default = 1
      flags = 0
      start = 41.666666666666664
      segment { length = 0 value = 1 1 expr = @fstart }
    }
    channel tboptionrange12 {
      lefttype = extend
      righttype = extend
      default = 240
      flags = 0
      start = 41.666666666666664
      segment { length = 0 value = 240 240 expr = @fend }
    }
    channel optionfloatvalue1 {
      lefttype = extend
      righttype = extend
      flags = 0
      start = 41.666666666666664
      segment { length = 0 expr = "node = hou.pwd()
frame = hou.frame()
shot_seq = hou.node(\"../\")
num_shots = shot_seq.evalParm(\"shots\")

iteration = 0
for i in range(1, num_shots + 1):
    start = shot_seq.evalParm(f\"startframe{i}\") + shot_seq.evalParm(\"seq_startframe\")
    if frame >= start:
        iteration = i - 1  # zero-based iteration
    else:
        break

return iteration" language = python }
    }
  }

