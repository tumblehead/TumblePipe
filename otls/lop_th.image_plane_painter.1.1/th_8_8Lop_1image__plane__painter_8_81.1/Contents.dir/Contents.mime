Content-Disposition: attachment; filename="hdaroot/layer_mesh/sopnet/create/color_from_image.chn"
Content-Type: text/plain

{
    channel filename {
      lefttype = extend
      righttype = extend
      defaultString = "\"node = hou.pwd()
layer = node.node(\\\"../../..\\\").evalParm(\\\"layer\\\")
cop_output = node.node(f\\\"../../../../cop_sopnet/copnet/{layer}\\\").path()

return f\\\"op:{cop_output}\\\"\""
      flags = 0
      segment { length = 0 expr = "node = hou.pwd()
layer = node.node(\"../../..\").evalParm(\"layer\")
cop_output = node.node(f\"../../../../cop_sopnet/copnet/{layer}\").path()

return f\"op:{cop_output}\"" language = python }
    }
  }

