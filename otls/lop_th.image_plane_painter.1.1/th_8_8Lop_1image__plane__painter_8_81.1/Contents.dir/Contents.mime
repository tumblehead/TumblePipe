--HOUDINIMIMEBOUNDARY0xD3ADD339-0x00000F49-0x56B122C9-0x00000001HOUDINIMIMEBOUNDARY
Content-Disposition: attachment; filename="hdaroot/foreach_layer.chn"
Content-Type: text/plain

{
    channel strings {
      lefttype = extend
      righttype = extend
      defaultString = \"\"
      flags = 0
      segment { length = 0 expr = "copnet = hou.pwd().node('../cop_sopnet/copnet')
layers = [l.attribValue(\"name\") for l in copnet.geometry().prims()]
layers.remove(\"C\")
split_layer_toggle = hou.pwd().parent().evalParm(\"split_layers\")
return \" \".join(layers) if split_layer_toggle else \"C\"" language = python }
    }
  }

