      lefttype = extend
      righttype = extend
      defaultString = ch(\"../../../layer\")
      flags = 0
      segment { length = 0 expr = "node = hou.pwd()
image_copnet = node.node(\"../../../../cop_sopnet/copnet\")
layer = hou.node(\"../../..\").evalParm(\"layer\")
layer_node = image_copnet.node(layer)
return layer_node.path()" language = python }
    }
    channel step {
      lefttype = extend
      righttype = extend
      default = 79.049999999999997
      flags = 0
      segment { length = 0 value = 79.049999999999997 79.049999999999997 expr = ch(\"../../../../step\") }
    }
  }

