--HOUDINIMIMEBOUNDARY0xD3ADD339-0x00000F49-0x56B122C9-0x00000001HOUDINIMIMEBOUNDARY
Content-Disposition: attachment; filename="hdaroot/objects/from_stage/scene.parm"
Content-Type: text/plain

{
version 0.8
loppath	[ 0	locks=0 ]	(	../../../../../IN_stage	)
primpattern	[ 0	locks=0 ]	(	/SET	)
excludeinactiveprims	[ 0	locks=0 ]	(	"off"	)
purpose	[ 0	locks=0 ]	(	proxy	)
importtraversal	[ 0	locks=0 ]	(	none	)
striplayers	[ 0	locks=0 ]	(	"off"	)
timesample	[ 0	locks=0 ]	(	"static"	)
importframe	[ 0	locks=0 ]	(	[ importframe	0 ] 	)
staticimportframe	[ 0	locks=0 ]	(	1001	)
sepparm	[ 0	locks=0 ]	(	)
