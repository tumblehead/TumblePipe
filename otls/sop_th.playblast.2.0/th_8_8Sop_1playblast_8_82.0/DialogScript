# Dialog script for th::playblast::2.0 automatically generated

{
    name	th::playblast::2.0
    script	Tumblehead::th_playblast::1.0
    label	"th playblast"

    help {
	""
    }

    inputlabel	1	"Sub-Network Input #1"
    inputlabel	2	"Sub-Network Input #2"
    inputlabel	3	"Sub-Network Input #3"
    inputlabel	4	"Sub-Network Input #4"

    groupsimple {
        name    "context"
        label   "Context"

        parm {
            name    "entity_select"
            label   "Entity"
            type    button
            joinnext
            default { "0" }
            parmtag { "button_icon" "hicon:/SVGIcons.index?BUTTONS_tree_full.svg" }
            parmtag { "script_callback" "hou.phm().select()" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "entity"
            label   "Entity"
            type    string
            invisible
            nolabel
            joinnext
            default { "from_context" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "entity_label"
            label   "entity_label"
            type    label
            nolabel
            default { "from_context: none" }
        }
        parm {
            name    "department"
            label   "Department"
            type    string
            joinnext
            default { "from_context" }
            menu {
                [ "from tumblepipe.pipe.houdini.sops import playblast" ]
                [ "from tumblepipe.pipe.houdini import util" ]
                [ "" ]
                [ "node = playblast.Playblast(hou.pwd())" ]
                [ "items = node.list_department_names()" ]
                [ "return util.list_to_menu(items)" ]
                language python
            }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "department_label"
            label   "department_label"
            type    label
            nolabel
            default { "" }
        }
        parm {
            name    "camera"
            label   "Camera"
            type    string
            default { "" }
            menu {
                [ "from tumblepipe.pipe.houdini.sops import playblast" ]
                [ "from tumblepipe.pipe.houdini import util" ]
                [ "" ]
                [ "node = playblast.Playblast(hou.pwd())" ]
                [ "paths = node.list_camera_paths()" ]
                [ "names = [ path.rsplit('/', 1)[-1] for path in paths ]" ]
                [ "return util.list_to_menu(names)" ]
                language python
            }
            parmtag { "script_callback_language" "python" }
        }
    }

    groupsimple {
        name    "actions"
        label   "Actions"

        parm {
            name    "playblast"
            label   "Playblast"
            type    button
            joinnext
            default { "0" }
            parmtag { "script_callback" "hou.phm().export()" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "view_latest"
            label   "View Latest"
            type    button
            joinnext
            default { "0" }
            parmtag { "script_callback" "hou.phm().view_latest()" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "browse_all"
            label   "Browse All"
            type    button
            default { "0" }
            parmtag { "script_callback" "hou.phm().open_location()" }
            parmtag { "script_callback_language" "python" }
        }
    }

}
