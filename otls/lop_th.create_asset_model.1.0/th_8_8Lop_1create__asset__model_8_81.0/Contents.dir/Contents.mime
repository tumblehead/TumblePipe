    parm {
        name    "lop_activation"
        label   "Activation"
        type    integer
        default { "1" }
        range   { 0 1 }
    }
    parm {
        name    "setsavepath"
        baseparm
        label   "Set Save Path"
        joinnext
        export  none
    }
    parm {
        name    "savepath"
