# Dialog script for th::create_asset_model::1.0 automatically generated

{
    name	th::create_asset_model::1.0
    script	th::create_asset_model::1.0
    label	"th create asset model"

    help {
	""
    }

    inputlabel	1	"Input Stage"
    inputlabel	2	"Input 2"
    inputlabel	3	"Input 3"
    inputlabel	4	"Input 4"

    groupsimple {
        name    "folder1"
        label   "Asset Definition"

        parm {
            name    "use_entity"
            label   "Primitive"
            type    buttonstrip
            default { "1" }
            menureplace {
                "0" "Path"
                "1" "Entity"
            }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "entity_select"
            label   "Entity"
            type    button
            joinnext
            default { "0" }
            hidewhen "{ use_entity == 0 }"
            parmtag { "button_icon" "hicon:/SVGIcons.index?BUTTONS_tree_full.svg" }
            parmtag { "script_callback" "hou.phm().select_entity()" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "entity"
            label   "Entity"
            type    string
            invisible
            nolabel
            joinnext
            default { "from_context" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "entity_label"
            label   "entity_label"
            type    label
            nolabel
            default { "from_context: none" }
            hidewhen "{ use_entity == 0 }"
        }
        parm {
            name    "primpath"
            label   "Primitive Path"
            type    string
            default { "`lopinputprim('.', 0)`" }
            hidewhen "{ use_entity == 1 }"
            menureplace {
                [ "opmenu -l -a add_model_variants2 primpath" ]
            }
            parmtag { "autoscope" "0000000000000000" }
            parmtag { "script_action" "import loputils\nloputils.selectPrimsInParm(kwargs, False)" }
            parmtag { "script_action_help" "Select a primitive in the Scene Viewer or Scene Graph Tree pane.\nCtrl-click to select using the primitive picker dialog.\nAlt-click to toggle movement of the display flag." }
            parmtag { "script_action_icon" "BUTTONS_reselect" }
            parmtag { "sidefx::usdpathtype" "prim" }
        }
        parm {
            name    "effective_primpath"
            label   "effective_primpath"
            type    string
            invisible
            default { "`pythonexprs(\"hou.phm().effective_primpath(hou.pwd())\")`" }
        }
        parm {
            name    "sublayer"
            label   "Create Sublayer"
            type    toggle
            default { "0" }
            parmtag { "script_callback_language" "python" }
        }
        groupcollapsible {
            name    "folder0"
            label   "Geometry Handling"

            parm {
                name    "packedhandling"
                label   "Packed Primitives"
                type    string
                default { "nativeinstances" }
                menu {
                    "xforms"            "Create Xforms"
                    "pointinstancer"    "Create Point Instancer"
                    "nativeinstances"   "Create Native Instances"
                    "unpack"            "Unpack"
                }
                parmtag { "autoscope" "0000000000000000" }
                parmtag { "script_callback_language" "python" }
            }
            parm {
                name    "polygonsassubd"
                label   "Treat Polygons as Subdivision Surfaces"
                type    toggle
                default { "off" }
                parmtag { "autoscope" "0000000000000000" }
                parmtag { "script_callback_language" "python" }
            }
        }

    }

    groupsimple {
        name    "folder2"
        label   "Variants"

        parm {
            name    "variantset"
            label   "Variant Set"
            type    string
            default { "model" }
            parmtag { "autoscope" "0000000000000000" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "active_variant"
            label   "Active Variant"
            type    string
            default { "0" }
            menu {
                [ "node = kwargs['node']" ]
                [ "num = node.parm('variants').eval()" ]
                [ "" ]
                [ "menu = []" ]
                [ "for i in range(num):" ]
                [ "    token = i" ]
                [ "    label = node.parm(f'variant_name{i+1}').eval()  # multiparm is 1-indexed but USD wants 0-indexed token" ]
                [ "    menu.extend([token, label])" ]
                [ "" ]
                [ "return menu" ]
                language python
            }
            parmtag { "autoscope" "0000000000000000" }
            parmtag { "script_callback_language" "python" }
        }
        multiparm {
            name    "variants"
            label    "Variants"
            parmtag { "multistartoffset" "1" }
            parmtag { "script_callback" "hou.phm().add_variant(kwargs)" }
            parmtag { "script_callback_language" "python" }

            groupsimple {
                name    "variant#"
                label   "Variant#"
                grouptag { "sidefx::look" "blank" }

                parm {
                    name    "variant_name#"
                    label   "variant"
                    type    string
                    joinnext
                    default { "variant#" }
                    parmtag { "editor" "0" }
                    parmtag { "script_callback" "hou.phm().on_variant_name(kwargs)" }
                    parmtag { "script_callback_language" "python" }
                }
                parm {
                    name    "jump_to_variant#"
                    label   "Jump to Output"
                    type    button
                    nolabel
                    default { "0" }
                    parmtag { "button_icon" "BUTTONS_jump" }
                    parmtag { "script_callback" "hou.phm().jump_to_variant(kwargs)" }
                    parmtag { "script_callback_language" "python" }
                }
            }

        }

    }

}
