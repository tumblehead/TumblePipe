# Dialog script for th::import_asset::1.0 automatically generated

{
    name	th::import_asset::1.0
    script	th::import_asset::1.0
    label	"th import asset"

    help {
	""
    }

    inputlabel	1	"Input Stage"
    inputlabel	2	"Input 2"
    inputlabel	3	"Input 3"
    inputlabel	4	"Input 4"

    groupsimple {
        name    "hidden_parms"
        label   "hidden_parms"
        invisibletab

        groupsimple {
            name    "import_parms"
            label   "import"

            parm {
                name    "import_filepath1"
                label   "File"
                type    geometry
                default { "" }
                parmtag { "autoscope" "0000000000000000" }
                parmtag { "filechooser_pattern" "*.usd*, *.mtlx, *.abc, *.bgeo*, *.gltf, *.glb, *.fbx, *.sbsar" }
            }
        }

        groupsimple {
            name    "metadata_parms"
            label   "metadata"

            parm {
                name    "metadata_python"
                label   "Python Code"
                type    string
                default { "" }
                menureplace {
                    [ "opmenu -l -a metadata python" ]
                }
                parmtag { "autoscope" "0000000000000000" }
                parmtag { "editor" "1" }
                parmtag { "editorlang" "python" }
                parmtag { "editorlines" "20-50" }
            }
        }

    }

    groupsimple {
        name    "selection"
        label   "Selection"

        parm {
            name    "entity_select"
            label   "Entity"
            type    button
            joinnext
            default { "0" }
            parmtag { "button_icon" "hicon:/SVGIcons.index?BUTTONS_tree_full.svg" }
            parmtag { "script_callback" "hou.phm().select()" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "entity"
            label   "Entity"
            type    string
            invisible
            nolabel
            joinnext
            default { "" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "entity_label"
            label   ""
            type    label
            nolabel
            default { "" }
        }
        parm {
            name    "variant"
            label   "Variant"
            type    string
            default { "default" }
            menu {
                [ "from tumblepipe.pipe.houdini.lops import import_asset" ]
                [ "from tumblepipe.pipe.houdini import util" ]
                [ "" ]
                [ "node = import_asset.ImportAsset(hou.pwd())" ]
                [ "items = node.list_variant_names()" ]
                [ "return util.list_to_menu(items)" ]
                language python
            }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "version"
            label   "Version"
            type    string
            joinnext
            default { "latest" }
            menu {
                [ "from tumblepipe.pipe.houdini.lops import import_asset" ]
                [ "from tumblepipe.pipe.houdini import util" ]
                [ "" ]
                [ "node = import_asset.ImportAsset(hou.pwd())" ]
                [ "items = node.list_version_names()" ]
                [ "return util.list_to_menu(items)" ]
                language python
            }
            parmtag { "script_callback" "" }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "version_label"
            label   "version_label"
            type    label
            nolabel
            default { "" }
        }
    }

    groupsimple {
        name    "settings"
        label   "Settings"

        parm {
            name    "departments"
            label   "Exclude departments"
            type    string
            default { "" }
            menutoggle {
                [ "from tumblepipe.pipe.houdini.lops import import_asset" ]
                [ "from tumblepipe.pipe.houdini import util" ]
                [ "" ]
                [ "node = import_asset.ImportAsset(hou.pwd())" ]
                [ "items = node.list_department_names()" ]
                [ "return util.list_to_menu(items)" ]
                language python
            }
            parmtag { "script_callback_language" "python" }
        }
        parm {
            name    "include_layerbreak"
            label   "Include layerbreak"
            type    toggle
            default { "on" }
            parmtag { "script_callback_language" "python" }
        }
    }

    groupsimple {
        name    "actions"
        label   "Actions"

        parm {
            name    "import"
            label   "Import"
            type    button
            default { "0" }
            parmtag { "script_callback" "hou.phm().execute()" }
            parmtag { "script_callback_language" "python" }
        }
    }

