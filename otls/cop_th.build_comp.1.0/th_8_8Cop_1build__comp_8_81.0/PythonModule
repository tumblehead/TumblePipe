from tumblepipe.pipe.houdini.cops import build_comp
from importlib import reload

def update():
    reload(build_comp)
    build_comp.update()

def stop():
    reload(build_comp)
    build_comp.stop()

def preview():
    reload(build_comp)
    build_comp.preview()

def submit():
    reload(build_comp)
    build_comp.submit()