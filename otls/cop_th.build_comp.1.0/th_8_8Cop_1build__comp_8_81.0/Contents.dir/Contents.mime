--HOUDINIMIMEBOUNDARY0xD3ADD339-0x00000F49-0x56B122C9-0x00000001HOUDINIMIMEBOUNDARY
Content-Disposition: attachment; filename="hdaroot/proxy/tops/generate.parm"
Content-Type: text/plain

{
version 0.8
savenodescript	[ 0	locks=0 ]	(	0	)
savenodehda	[ 0	locks=0 ]	(	0	)
sepparm2	[ 0	locks=0 ]	(	)
processor	[ 0	locks=0 ]	(	0	0	0	)
pdg_workitemgeneration	[ 0	locks=0 ]	(	"2"	)
pdg_command	[ 0	locks=0 ]	(	""	)
sepparm	[ 0	locks=0 ]	(	)
callbacks	[ 0	locks=0 ]	(	0	0	0	0	0	)
generate	[ 0	locks=0 ]	(	"import hou

from tumblepipe.pipe.houdini.cops import build_comp
from tumblepipe.pipe.paths import get_render, get_aov_frame_path
from tumblepipe.api import path_str, default_client

api = default_client()
context = build_comp.BuildComp(hou.pwd().parent().parent().parent())

sequence_name = context.get_sequence_name()
shot_name = context.get_shot_name()
render_department_name = context.get_render_department_name()
resolution_name = context.get_proxy_resolution()
start_frame, end_frame = api.config.get_frame_range(sequence_name, shot_name)
render_layer_names = api.config.list_render_layer_names(sequence_name, shot_name)

def _aov_included(aov_name):
    if aov_name.startswith('C_'): return True
    if aov_name.startswith('objid_'): return True
    if aov_name == 'C': return True
    if aov_name == 'N': return True
    if aov_name == 'P': return True
    if aov_name == 'Z': return True
    if aov_name == 'A': return True
    if aov_name == 'albedo': return True
    if aov_name == 'color': return True
    if aov_name == 'normal': return True
    if aov_name == 'position': return True
    if aov_name == 'depth': return True
    if aov_name == 'alpha': return True
    return False

def _task_type(aov_name):
    if aov_name.startswith('C_'): return 'rgba'
    if aov_name == 'sampleCount': return 'mono'
    if aov_name == 'C': return 'rgba'
    return 'rgb'

def _scale(resolution):
    match resolution:
        case 'full': return 1.0
        case 'half': return 2.0
        case 'quarter': return 4.0
        case _: assert False, f'Unknown resolution {resolution}'

import_render = get_render(
    sequence_name,
    shot_name,
    render_department_name,
    purpose = 'render'
)

for render_layer_name in render_layer_names:
    if import_render is None: continue
    
    render_layer = import_render.get_latest_complete_layer(render_layer_name)
    if render_layer is None: continue
    
    import_normal_path = render_layer.get_aov_frame_path('normal', '$F')
    import_albedo_path = render_layer.get_aov_frame_path('albedo', '$F')
    
    for aov_name, aov in render_layer.aovs.items():
    
        if not _aov_included(aov_name): continue
    
        export_aov_path = get_aov_frame_path(
            sequence_name,
            shot_name,
            resolution_name,
            render_layer_name,
            aov_name,
            render_layer.version,
            '$F',
            purpose = 'proxy'
        )
        if export_aov_path.exists(): continue
        
        import_aov_path = aov.get_aov_frame_path('$F')
        
        task = item_holder.addWorkItem()
        task.addAttrib('task_type', pdg.attribType.String)
        task.addAttrib('import_path', pdg.attribType.String)
        task.addAttrib('import_normal_path', pdg.attribType.String)
        task.addAttrib('import_albedo_path', pdg.attribType.String)
        task.addAttrib('export_path', pdg.attribType.String)
        task.addAttrib('aov_name', pdg.attribType.String)
        task.addAttrib('scale', pdg.attribType.Float)
        task.addAttrib('start_frame', pdg.attribType.Int)
        task.addAttrib('end_frame', pdg.attribType.Int)
        
        task_type = _task_type(aov_name)
        task.setStringAttrib('task_type', task_type)
        task.setStringAttrib('import_path', path_str(import_aov_path))
        if task_type == 'lpe':
            task.setStringAttrib('import_normal_path', path_str(import_normal_path))
            task.setStringAttrib('import_albedo_path', path_str(import_albedo_path))
        task.setStringAttrib('export_path', path_str(export_aov_path))
        task.setStringAttrib('aov_name', aov_name)
        task.setFloatAttrib('scale', _scale(resolution_name))
        task.setIntAttrib('start_frame', start_frame)
        task.setIntAttrib('end_frame', end_frame)"	)
useregeneratestatic	[ 0	locks=0 ]	(	"off"	)
regeneratestatic	[ 0	locks=0 ]	(	"# Called when this node may need to regenerate existing work items
#
# self           -   A reference to the current pdg.Node instance
# item_holder    -   A pdg.WorkItemHolder for constructing and adding new work items
# existing_items -   The existing work items in the node
# upstream_items -   The list of work items in the node above, or empty list
# generation_type -   The type of generation, e.g. pdg.generationType.Static, Dynamic, or Regenerate"	)
addinternaldependencies	[ 0	locks=0 ]	(	"# Called when the node has generated work items so that dependencies can
# be added between work items in this node.
#
# self              -   A reference to the current pdg.Node instance
# dependency_holder -   A pdg.WorkItemHolder for adding pairs of items that should have a dependency
# internal_items    -   The list of items, either all static items or a group of dynamic items
# is_static         -   Boolean indicating if the items list contains static items
"	)
cooktask	[ 0	locks=0 ]	(	"# Called when an in process work item needs to cook. In process work items
# are created by passing the `inProcess=True` flag when constructing the item in
# the `Generate` callback
#
# self              -   A reference to the current pdg.Node instance
# work_item         -   The work item being cooked by this callback"	)
servicename	[ 0	locks=0 ]	(	""	)
sepparm3	[ 0	locks=0 ]	(	)
alwaysregenerate	[ 0	locks=0 ]	(	"off"	)
dirtyonregenerate	[ 0	locks=0 ]	(	"off"	)
dirtyonincomplete	[ 0	locks=0 ]	(	"off"	)
sepparm4	[ 0	locks=0 ]	(	)
requiresgeneratedinputs	[ 0	locks=0 ]	(	"off"	)
