requiresscenefile	[ 0	locks=0 ]	(	"off"	)
requiresinputdata	[ 0	locks=0 ]	(	"off"	)
sepparm6	[ 0	locks=0 ]	(	)
usesdynamicbatching	[ 0	locks=0 ]	(	"off"	)
sepparm7	[ 0	locks=0 ]	(	)
usestatefilter	[ 0	locks=0 ]	(	"off"	)
