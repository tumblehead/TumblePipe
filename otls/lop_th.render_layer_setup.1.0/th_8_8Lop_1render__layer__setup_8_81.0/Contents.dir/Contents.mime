{
    channel sample_f1 {
      lefttype = extend
      righttype = extend
      default = 1
      flags = 0
      start = 41.666666666666664
      segment { length = 0 value = 1 1 expr = @fstart }
    }
    channel sample_f2 {
      lefttype = extend
      righttype = extend
      default = 240
      flags = 0
      start = 41.666666666666664
      segment { length = 0 value = 240 240 expr = @fend }
    }
    channel sample_f3 {
      lefttype = extend
      righttype = extend
      default = 1
      flags = 0
      start = 41.666666666666664
      segment { length = 0 value = 1 1 expr = @finc }
    }
    channel xn__primvarskarmaobjectrendervisibility_4xbfg {
      lefttype = extend
      righttype = extend
      defaultString = \"-primary\"
      flags = 0
      start = 41.666666666666664
      segment { length = 0 expr = chs(\"../xn__primvarskarmaobjectrendervisibility_4xbfg\") }
    }
    channel xn__primvarskarmaobjectholdoutmode_zpbfg {
      lefttype = extend
      righttype = extend
      flags = 0
      start = 41.666666666666664
      segment { length = 0 expr = ch(\"../xn__primvarskarmaobjectholdoutmode_zpbfg\") }
    }
  }

