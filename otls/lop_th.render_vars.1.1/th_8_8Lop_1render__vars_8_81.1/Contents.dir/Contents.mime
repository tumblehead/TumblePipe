    group {
        name    "settings2_1"
        label   "Karma"

        parm {
            name    "xn__driverparametersaovkarmafilter_control_y2bkdf"
            label   "Pixel Filter"
            type    string
            default { "none" }
            menujoin {
                [ "import loputils" ]
                [ "return loputils.createEditPropertiesControlMenu(kwargs, 'string')" ]
                language python
            }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "xn__driverparametersaovkarmafilter_xpbkdf"
            label   "Pixel Filter"
            type    string
            default { "" }
            disablewhen "{ xn__driverparametersaovkarmafilter_control_y2bkdf == block } { xn__driverparametersaovkarmafilter_control_y2bkdf == none }"
            menureplace {
                "[\"ubox\",{}]"                     "Average Samples"
                "[\"minmax\",{\"mode\":\"min\"}]"   "Sample: Minimum Value"
                "[\"minmax\",{\"mode\":\"max\"}]"   "Sample: Maximum Value"
            }
            parmtag { "spare_category" "Image" }
            parmtag { "uiscope" "None" }
            parmtag { "usdapischema" "KarmaRenderVarAPI" }
            parmtag { "usdvaluetype" "string" }
        }
        parm {
            name    "xn__driverparametersaovkarmadither_control_y2bkdf"
            label   "Dithering"
            type    string
            default { "none" }
            menujoin {
                [ "import loputils" ]
                [ "return loputils.createEditPropertiesControlMenu(kwargs, 'float')" ]
                language python
            }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "xn__driverparametersaovkarmadither_xpbkdf"
            label   "Dithering"
            type    float
            default { "1" }
            disablewhen "{ xn__driverparametersaovkarmadither_control_y2bkdf == block } { xn__driverparametersaovkarmadither_control_y2bkdf == none }"
            range   { 0! 1 }
            parmtag { "spare_category" "Image" }
            parmtag { "uiscope" "None" }
            parmtag { "usdapischema" "KarmaRenderVarAPI" }
            parmtag { "usdvaluetype" "float" }
        }
        parm {
            name    "xn__driverparametersaovkarmadefaultvalue_control_qdckdf"
            label   "Default value"
            type    string
            default { "none" }
            menujoin {
                [ "import loputils" ]
                [ "return loputils.createEditPropertiesControlMenu(kwargs, 'float')" ]
                language python
            }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "xn__driverparametersaovkarmadefaultvalue_pzbkdf"
            label   "Default value"
            type    float
            default { "0" }
            disablewhen "{ xn__driverparametersaovkarmadefaultvalue_control_qdckdf == block } { xn__driverparametersaovkarmadefaultvalue_control_qdckdf == none }"
            range   { 0 10 }
            parmtag { "spare_category" "Image" }
            parmtag { "uiscope" "None" }
            parmtag { "usdapischema" "KarmaRenderVarAPI" }
            parmtag { "usdvaluetype" "float" }
        }
        parm {
            name    "xn__driverparametersaovkarmacryptomatte_control_3bckdf"
            label   "Enable Cryptomatte"
            type    string
            default { "none" }
            menujoin {
                [ "import loputils" ]
                [ "return loputils.createEditPropertiesControlMenu(kwargs, 'bool')" ]
                language python
            }
