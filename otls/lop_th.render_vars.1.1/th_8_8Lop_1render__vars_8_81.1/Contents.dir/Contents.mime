--HOUDINIMIMEBOUNDARY0xD3ADD339-0x00000F49-0x56B122C9-0x00000001HOUDINIMIMEBOUNDARY
Content-Disposition: attachment; filename="hdaroot/samples.chn"
Content-Type: text/plain

{
    channel sample_f1 {
      lefttype = extend
      righttype = extend
      default = 1
      flags = 0
      segment { length = 0 value = 1 1 expr = @ropstart }
    }
    channel sample_f2 {
      lefttype = extend
      righttype = extend
      default = 240
      flags = 0
      segment { length = 0 value = 240 240 expr = @ropend }
    }
    channel sample_f3 {
      lefttype = extend
      righttype = extend
      default = 1
      flags = 0
      segment { length = 0 value = 1 1 expr = @ropinc }
    }
    channel lop_activation {
      lefttype = extend
      righttype = extend
      flags = 0
      segment { length = 0 expr = ch(\"../sample_count\") }
    }
  }

--HOUDINIMIMEBOUNDARY0xD3ADD339-0x00000F49-0x56B122C9-0x00000001HOUDINIMIMEBOUNDARY
Content-Disposition: attachment; filename="hdaroot/samples.parm"
Content-Type: text/plain

{
version 0.8
sample_group	[ 0	locks=0 ]	(	0	)
sample_behavior	[ 0	locks=0 ]	(	single	)
sample_f	[ 0	locks=0 ]	(	[ sample_f1	1 ] 	[ sample_f2	240 ] 	[ sample_f3	1 ] 	)
sample_subframeenable	[ 0	locks=0 ]	(	"off"	)
sample_subframegroup	[ 0	locks=0 ]	(	0	)
sample_shuttermode	[ 0	locks=0 ]	(	manual	)
sample_shutterrange	[ 0	locks=0 ]	(	-0.25	0.25	)
sample_cameraprim	[ 0	locks=0 ]	(	/cameras/camera1	)
sample_count	[ 0	locks=0 ]	(	2	)
sample_includeframe	[ 0	locks=0 ]	(	"on"	)
sample_group2	[ 0	locks=0 ]	(	0	)
sample_subframegroup2	[ 0	locks=0 ]	(	0	)
primpattern	[ 0	locks=0 ]	(	"`lopinputprims('.', 0)`"	)
primpath	[ 0	locks=0 ]	(	/Render/Products/Vars/samples	)
createprims	[ 0	locks=0 ]	(	"on"	)
initforedit	[ 0	locks=0 ]	(	0	)
createprimsgroup2	[ 0	locks=0 ]	(	0	)
primcount	[ 0	locks=0 ]	(	1	)
primtype	[ 0	locks=0 ]	(	UsdRenderVar	)
primkind	[ 0	locks=0 ]	(	""	)
specifier	[ 0	locks=0 ]	(	def	)
classancestor	[ 0	locks=0 ]	(	""	)
parentprimtype	[ 0	locks=0 ]	(	UsdGeomScope	)
settings	[ 0	locks=0 ]	(	0	)
dataType_control	[ 0	locks=0 ]	(	set	)
dataType	[ 0	locks=0 ]	(	color3f	)
sourceName_control	[ 0	locks=0 ]	(	set	)
sourceName	[ 0	locks=0 ]	(	ray:pixelsamples	)
sourceType_control	[ 0	locks=0 ]	(	set	)
sourceType	[ 0	locks=0 ]	(	raw	)
sepparm	[ 0	locks=0 ]	(	)
xn__driverparametersaovname_control_krbkd	[ 0	locks=0 ]	(	set	)
xn__driverparametersaovname_jebkd	[ 0	locks=0 ]	(	samples	)
xn__driverparametersaovformat_control_tubkd	[ 0	locks=0 ]	(	set	)
xn__driverparametersaovformat_shbkd	[ 0	locks=0 ]	(	float	)
xn__driverparametersaovmultiSampled_control_l4bkd	[ 0	locks=0 ]	(	set	)
xn__driverparametersaovmultiSampled_krbkd	[ 0	locks=0 ]	(	"off"	)
xn__driverparametersaovclearValue_control_c1bkd	[ 0	locks=0 ]	(	set	)
xn__driverparametersaovclearValue_bobkd	[ 0	locks=0 ]	(	0	)
errorseverity	[ 0	locks=0 ]	(	"1"	)
errormsg	[ 0	locks=0 ]	(	"`ifs(ch(\"createprims\") == 1, ifs(strmatch(\"/Render/*\", chs(\"primpath\")), \"\", \"Render primitives should be created under the /Render branch.\"), \"\")`"	)
lop_activation	[ 0	locks=0 ]	(	[ lop_activation	0 ] 	)
sample_group3	[ 0	locks=0 ]	(	0	)
sample_subframegroup3	[ 0	locks=0 ]	(	0	)
createprimsgroup3	[ 0	locks=0 ]	(	0	)
settings2	[ 0	locks=0 ]	(	0	)
}

