            name    "xn__driverparametersaovhuskOpenEXRcompression_control_vlckdeh"
            label   "OpenEXR Compression"
            type    string
            default { "none" }
            menujoin {
                [ "import loputils" ]
                [ "return loputils.createEditPropertiesControlMenu(kwargs, 'string')" ]
                language python
            }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "xn__driverparametersaovhuskOpenEXRcompression_u7bkdeh"
            label   "OpenEXR Compression"
            type    string
            default { "zips" }
            disablewhen "{ xn__driverparametersaovhuskOpenEXRcompression_control_vlckdeh == block } { xn__driverparametersaovhuskOpenEXRcompression_control_vlckdeh == none }"
            menu {
                "none"  "No compression"
                "dwab"  "DWA-B, Lossy and Fast (256-scanline block)"
                "dwaa"  "DWA-A, Lossy and Fast (32-scanline block)"
                "piz"   "PIZ Wavelet"
                "rle"   "Runlength Encoding"
                "zips"  "ZIP (Single scanline)"
                "zip"   "ZIP (Multi-scanline blocks)"
                "pix"   "PXR24 (32 bit float compression, lossy)"
                "b44"   "B44 (4x4 block compression, lossy)"
                "b44a"  "B44A (4x4 block extra compression, lossy)"
            }
            parmtag { "spare_category" "Parameters" }
            parmtag { "uiscope" "None" }
            parmtag { "usdapischema" "HuskRenderVarAPI" }
            parmtag { "usdvaluetype" "string" }
        }
        parm {
            name    "xn__driverparametersaovhuskOpenEXRdwa_compression_control_esckdeh"
            label   "DWA Compression Level"
            type    string
            default { "none" }
            hidewhen "{ xn__driverparametersaovhuskOpenEXRcompression_u7bkdeh != dwaa xn__driverparametersaovhuskOpenEXRcompression_u7bkdeh != dwab }"
            menujoin {
                [ "import loputils" ]
                [ "return loputils.createEditPropertiesControlMenu(kwargs, 'int')" ]
                language python
            }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "xn__driverparametersaovhuskOpenEXRdwa_compression_dfckdeh"
            label   "DWA Compression Level"
            type    integer
            default { "85" }
            disablewhen "{ xn__driverparametersaovhuskOpenEXRdwa_compression_control_esckdeh == block } { xn__driverparametersaovhuskOpenEXRdwa_compression_control_esckdeh == none }"
            hidewhen "{ xn__driverparametersaovhuskOpenEXRcompression_u7bkdeh != dwaa xn__driverparametersaovhuskOpenEXRcompression_u7bkdeh != dwab }"
            range   { 1! 200 }
            parmtag { "spare_category" "Parameters" }
            parmtag { "uiscope" "None" }
            parmtag { "usdapischema" "HuskRenderVarAPI" }
            parmtag { "usdvaluetype" "int" }
        }
    }

    parm {
        name    "errorseverity"
        baseparm
        label   "Error Severity"
        invisible
        export  none
    }
    parm {
        name    "errormsg"
        baseparm
        label   "Error Message"
        invisible
        export  none
    }

--HOUDINIMIMEBOUNDARY0xD3ADD339-0x00000F49-0x56B122C9-0x00000001HOUDINIMIMEBOUNDARY
Content-Disposition: attachment; filename="hdaroot/albedo.chn"
Content-Type: text/plain

{
    channel sample_f1 {
      lefttype = extend
      righttype = extend
      default = 1
      flags = 0
      segment { length = 0 value = 1 1 expr = @ropstart }
    }
    channel sample_f2 {
      lefttype = extend
      righttype = extend
      default = 240
      flags = 0
      segment { length = 0 value = 240 240 expr = @ropend }
    }
    channel sample_f3 {
      lefttype = extend
      righttype = extend
      default = 1
      flags = 0
      segment { length = 0 value = 1 1 expr = @ropinc }
    }
    channel lop_activation {
      lefttype = extend
      righttype = extend
      default = 1
      flags = 0
      start = 41.666666666666664
      segment { length = 0 value = 1 1 expr = ch(\"../albedo\") }
    }
  }

