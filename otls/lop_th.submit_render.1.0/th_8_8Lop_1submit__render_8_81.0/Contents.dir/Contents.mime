--HOUDINIMIMEBOUNDARY0xD3ADD339-0x00000F49-0x56B122C9-0x00000001HOUDINIMIMEBOUNDARY
Content-Disposition: attachment; filename="hdaroot/overwrite_render_settings.chn"
Content-Type: text/plain

{
    channel sample_f1 {
      lefttype = extend
      righttype = extend
      default = 1
      flags = 0
      start = 41.666666666666664
      segment { length = 0 value = 1 1 expr = @fstart }
    }
    channel sample_f2 {
      lefttype = extend
      righttype = extend
      default = 240
      flags = 0
      start = 41.666666666666664
      segment { length = 0 value = 240 240 expr = @fend }
    }
    channel sample_f3 {
      lefttype = extend
      righttype = extend
      default = 1
      flags = 0
      start = 41.666666666666664
      segment { length = 0 value = 1 1 expr = @finc }
    }
    channel errormsg {
      lefttype = extend
      righttype = extend
      defaultString = \"\"
      flags = 0
      start = 41.666666666666664
      segment { length = 0 expr = __import__('loputils').renderProductAndSettingsErrorMessage() language = python }
    }
    channel resolution2 {
      lefttype = extend
      righttype = extend
      default = 1080
      flags = 0
      segment { options = {	 untie  iv ov is os ia oa }

	 length = 0 expr = "pythonexprf(\"__import__('loputils').computeResolutionParameter(True, False)\")" }
    }
    channel xn__karmaglobalsamplesperpixel_ejbg {
      lefttype = extend
      righttype = extend
      default = 9
      flags = 0
      start = 41.666666666666664
      segment { length = 0 value = 9 9 expr = ch(\"../samples\") }
    }
  }

