        parm {
            name    "matnet"
            baseparm
            label   "Material Network"
            export  none
        }
        parm {
            name    "containerpath"
            baseparm
            label   "Container Path"
            export  none
        }
        parm {
            name    "fillmaterials"
            baseparm
            label   "Auto-fill Materials"
            export  none
        }
    }

    multiparm {
        name    "materials"
        label    "Number of Materials"
        baseparm
        default 1
        parmtag { "multistartoffset" "1" }

        parm {
            name    "enable#"
            baseparm
            label   "Enable"
            joinnext
            export  none
        }
        parm {
