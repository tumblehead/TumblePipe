        name    "lop_activation"
        label   "Activation"
        type    integer
        default { "1" }
        range   { 0 1 }
    }
    parm {
        name    "python"
        baseparm
        label   "Python Code"
        export  none
    }
    parm {
        name    "asset"
        label   "asset"
        type    string
        default { "" }
        parmtag { "script_callback_language" "python" }
