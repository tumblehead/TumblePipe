def createViewerStateTemplate():
    """ Mandatory entry point to create and return the viewer state 
        template to register. """

    state_typename = kwargs["type"].definition().sections()["DefaultState"].contents()
    state_label = "Puzzle Matte State"
    state_cat = hou.lopNodeTypeCategory()

    extra_contexts = [hou.sopNodeTypeCategory()]
    template = hou.ViewerStateTemplate(state_typename, state_label, state_cat, contexts=extra_contexts)
    template.bindFactory(State)
    template.bindIcon(kwargs["type"].icon())

    menu = hou.ViewerStateMenu('rendervars_menu', "Render Vars Menu")

    menu.addToggleItem("render_var_viz", "Visualize Render Vars", default_value=False)

    menu.addRadioStrip("rendervars_strip", "Render Vars",  "default")

    menu.addRadioStripItem("rendervars_strip", "default", "Default")

    # Bind Menu to Templat
    template.bindMenu(menu)

    return template
