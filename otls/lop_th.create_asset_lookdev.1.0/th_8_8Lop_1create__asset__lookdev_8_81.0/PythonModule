def _sync_variants(node):
    """Reconcile null and output nodes with the current multiparm state.

    Manages both:
    - Output nodes inside lookdev_subnet (outputidx-keyed)
    - VARIANT{N}_OUT null nodes in lookdev_variant_subnet
    Removes orphans and fixes indices on add/remove/reorder.
    """
    count = node.parm("variants").eval()
    variant_subnet = node.node("lookdev_variant_subnet")
    lookdev_subnet = variant_subnet.node("lookdev_subnet")

    # --- Collect existing output nodes in lookdev_subnet keyed by outputidx ---
    existing_outputs = {}
    for n in lookdev_subnet.children():
        if n.type().name() == "output":
            existing_outputs[n.evalParm("outputidx")] = n

    # --- Collect existing null nodes keyed by their wired output index ---
    existing_nulls = {}
    for n in variant_subnet.children():
        if n.type().name() == "null" and n.name().startswith("VARIANT"):
            inputs = n.inputs()
            if inputs and inputs[0] is not None and inputs[0] == lookdev_subnet:
                for conn in n.inputConnections():
                    if conn.inputNode() == lookdev_subnet:
                        existing_nulls[conn.outputIndex()] = n
                        break
            else:
                # Null not wired — track by name
                name = n.name()
                try:
                    idx = int(name.replace("VARIANT", "").replace("_OUT", "")) - 1
                    existing_nulls[idx] = n
                except ValueError:
                    pass

    # --- Determine desired vs existing ---
    desired = set(range(count))
    have_outputs = set(existing_outputs.keys())
    have_nulls = set(existing_nulls.keys())

    # Remove orphaned nodes
    for idx in have_outputs - desired:
        existing_outputs[idx].destroy()
    for idx in have_nulls - desired:
        existing_nulls[idx].destroy()

    # --- Create missing nodes and fix indices ---
    for i in range(count):
        variant_idx = i + 1  # 1-based multiparm index
        variant_name = node.parm(f"variant_name{variant_idx}").eval()

        # Output node in lookdev_subnet
        if i in existing_outputs:
            out_node = existing_outputs[i]
        else:
            out_node = lookdev_subnet.createNode("output", f"VARIANT{variant_idx}_OUTPUT")
            out_node.parm("outputidx").set(i)
            out_node.moveToGoodPosition()

        # Ensure outputidx is correct
        if out_node.evalParm("outputidx") != i:
            out_node.parm("outputidx").set(i)

        try:
            out_node.setName(f"OUT_{variant_name}")
        except hou.OperationFailed:
            out_node.setName(f"VARIANT{variant_idx}_OUTPUT")

        # Null node in lookdev_variant_subnet
        if i in existing_nulls:
            null_node = existing_nulls[i]
        else:
            null_node = variant_subnet.createNode("null", f"VARIANT{variant_idx}_OUT")

        # Ensure null is wired to correct lookdev_subnet output
        null_node.setInput(0, lookdev_subnet, output_index=i)

        # Rename null to match variant index
        try:
            null_node.setName(f"VARIANT{variant_idx}_OUT")
        except hou.OperationFailed:
            pass



def _get_node(kwargs):
    """Get the HDA node from kwargs, falling back to hou.pwd()."""
    node = kwargs.get("node")
    if node is None:
        node = hou.pwd()
    return node


def _deferred_sync(node_path):
    """One-shot event loop callback to run sync after the callback returns."""
    def _do_sync():
        hou.ui.removeEventLoopCallback(_do_sync)
        node = hou.node(node_path)
        if node is not None:
            _sync_variants(node)
    return _do_sync


def add_variant(kwargs):
    """Multiparm callback — fires on both add and remove.

    Defers the actual sync to after the callback returns to avoid
    crashes from modifying the node graph mid-callback.
    """
    node = _get_node(kwargs)
    hou.ui.addEventLoopCallback(_deferred_sync(node.path()))


def on_variant_name(kwargs):
    """Variant name changed — rename the corresponding output node."""
    variant_idx = kwargs.get("script_multiparm_index")
    variant_name = kwargs.get("script_value")

    node = _get_node(kwargs)
    variant_subnet = node.node("lookdev_variant_subnet")
    lookdev_subnet = variant_subnet.node("lookdev_subnet")

    # Find output node by its outputidx
    target_idx = int(variant_idx) - 1
    for n in lookdev_subnet.children():
        if n.type().name() == "output" and n.evalParm("outputidx") == target_idx:
            try:
                n.setName(f"OUT_{variant_name}")
            except hou.OperationFailed:
                pass
            break


def jump_to_variant(kwargs):
    """Button callback — jump network editor to the variant's output node."""
    variant_idx = kwargs.get("script_multiparm_index")
    if variant_idx is None:
        return

    node = _get_node(kwargs)
    variant_name = node.parm(f"variant_name{variant_idx}").eval()
    target = node.node(f"lookdev_variant_subnet/lookdev_subnet/OUT_{variant_name}")
    if target is None:
        return

    target.setCurrent(True, clear_all_selected=True)

    for pane_tab in hou.ui.paneTabs():
        if pane_tab.type() == hou.paneTabType.NetworkEditor:
            pane_tab.setCurrentNode(target)
            pane_tab.homeToSelection()


FROM_CONTEXT = 'from_context'


def select_entity():
    """HDA button callback — open entity selector and sync entity parm."""
    from tumblepipe.pipe.houdini.ui.widgets import EntitySelectorDialog
    from tumblepipe.pipe.houdini.lops import import_asset

    node = hou.pwd()
    dialog = EntitySelectorDialog(
        api=import_asset.api,
        entity_filter='assets',
        include_from_context=True,
        current_selection=node.parm('entity').eval(),
        title="Select Asset",
        parent=hou.qt.mainWindow(),
    )
    if not dialog.exec_():
        return

    selected_uri = dialog.get_selected_uri()
    if not selected_uri:
        return

    _apply_entity(node, selected_uri)


def _resolve_from_context():
    """Return the asset URI string from the workfile context, or None."""
    from tumblepipe.pipe.paths import get_workfile_context
    from pathlib import Path
    try:
        ctx = get_workfile_context(Path(hou.hipFile.path()))
    except Exception:
        return None
    if ctx is None or ctx.entity_uri is None:
        return None
    if ctx.entity_uri.purpose != 'entity':
        return None
    uri_str = str(ctx.entity_uri)
    if not uri_str.startswith('entity:/assets/'):
        return None
    return uri_str


def _apply_entity(node, value):
    """Write entity URI (or 'from_context' sentinel) into the node's parms.

    For 'from_context' the entity parm holds the sentinel literal and the
    label shows the dynamically-resolved URI (or 'none' if it can't be
    resolved yet). For an explicit URI both parms get the same string.
    """
    if value == FROM_CONTEXT:
        node.parm('entity').set(FROM_CONTEXT)
        resolved = _resolve_from_context()
        node.parm('entity_label').set(
            f'from_context: {resolved}' if resolved else 'from_context: none'
        )
    else:
        raw = str(value)
        node.parm('entity').set(raw)
        node.parm('entity_label').set(raw)


def effective_primpath(node):
    """Resolve the primpath internal LOPs should consume.

    In entity mode (`use_entity == 1`) the path is derived from `entity` via
    `uri_to_prim_path`. The 'from_context' sentinel resolves to the current
    workfile's asset URI. In direct mode it falls back to the `primpath`
    parm. Called from hscript `pythonexprs(...)` on the hidden
    `effective_primpath` parm, which the internals reference via
    `chs("../effective_primpath")`.
    """
    if node.parm('use_entity').eval():
        entity = node.parm('entity').eval()
        if entity == FROM_CONTEXT:
            entity = _resolve_from_context()
        if entity:
            from tumblepipe.pipe.houdini.util import uri_to_prim_path
            from tumblepipe.util.uri import Uri
            try:
                return uri_to_prim_path(Uri.parse_unsafe(entity))
            except ValueError:
                pass
    return node.parm('primpath').eval()


def init_entity_from_context(node):
    """Set entity to the 'from_context' sentinel and refresh the label."""
    _apply_entity(node, FROM_CONTEXT)
