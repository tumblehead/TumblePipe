n_hasFlag = n.isMaterialFlagSet()
i = n.evalParm('inherit_ctrl')
r = 'none'
if i == 1 or (n_hasFlag and i == 2):
    r = 'inherit'
return r" ] 	)
shader_baseprimpath	[ 0	locks=0 ]	(	/__class_mtl__/`$OS`	)
