            disablewhen "{ bump_style != 1 } { thin_film_thickness_file_control == block } { thin_film_thickness_file_control == none } { thin_film_thickness_file_control == disconnectinput }"
            parmtag { "parmvop" "1" }
            parmtag { "script_action" "import loptoolutils;loptoolutils.setupCopNetForMap(kwargs=kwargs)" }
            parmtag { "script_action_help" "Create COP texture for this map. Hold Ctrl/Cmd to start a new copnet." }
            parmtag { "script_action_icon" "NETWORKS_cop" }
            parmtag { "usdvaluename" "inputs:thin_film_thickness_file" }
            parmtag { "usdvaluetype" "asset" }
        }
    }

    groupcollapsible {
        name    "folder0_8"
        label   "Geometry"
        grouptag { "group_type" "collapsible" }
        parmtag { "sidefx::header_parm" "thin_walled" }

        parm {
            name    "thin_walled_control"
            label   "thin_walled"
            type    string
            default { "none" }
            menujoin {
                [ "import loputils" ]
                [ "return loputils.createEditPropertiesControlMenu(" ]
                [ "           kwargs, 'int', 'inputs:thin_walled', True, False)" ]
                language python
            }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "thin_walled"
            label   "Thin Walled"
            type    toggle
            default { [ "off" hscript-expr ] }
            disablewhen "{ thin_walled_control == block } { thin_walled_control == none } { thin_walled_control == disconnectinput }"
            parmtag { "parmvop" "1" }
            parmtag { "usdvaluename" "inputs:thin_walled" }
            parmtag { "usdvaluetype" "int" }
        }
        parm {
            name    "opacity_control"
            label   "opacity"
            type    string
            default { "none" }
            menujoin {
                [ "import loputils" ]
                [ "return loputils.createEditPropertiesControlMenu(" ]
                [ "           kwargs, 'color3f', 'inputs:opacity', True, False)" ]
                language python
            }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "opacity"
            label   "Opacity"
            type    color
            size    3
            default { "1" "1" "1" }
            disablewhen "{ opacity_control == block } { opacity_control == none } { opacity_control == disconnectinput }"
            range   { 0 1 }
            parmtag { "parmvop" "1" }
            parmtag { "usdvaluename" "inputs:opacity" }
            parmtag { "usdvaluetype" "color3f" }
        }
        parm {
            name    "opacity_file_control"
            label   "opacity_file"
            type    string
            default { "none" }
            menujoin {
                [ "import loputils" ]
                [ "return loputils.createEditPropertiesControlMenu(" ]
                [ "           kwargs, 'asset', 'inputs:opacity_file', True, False)" ]
                language python
            }
            parmtag { "sidefx::look" "icon" }
        }
        parm {
            name    "opacity_file"
            label   "Opacity Map"
            type    image
            default { "" }
            disablewhen "{ opacity_file_control == block } { opacity_file_control == none } { opacity_file_control == disconnectinput }"
            parmtag { "parmvop" "1" }
            parmtag { "script_action" "import loptoolutils;loptoolutils.setupCopNetForMap(kwargs=kwargs)" }
            parmtag { "script_action_help" "Create COP texture for this map. Hold Ctrl/Cmd to start a new copnet." }
            parmtag { "script_action_icon" "NETWORKS_cop" }
            parmtag { "usdvaluename" "inputs:opacity_file" }
