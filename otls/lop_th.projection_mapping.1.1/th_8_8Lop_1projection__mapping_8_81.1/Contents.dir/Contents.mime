triplanar_blend	[ 0	locks=0 ]	(	0.25	)
triplanar_upaxis_control	[ 0	locks=0 ]	(	set	)
triplanar_upaxis	[ 0	locks=0 ]	(	1	)
displacement_control	[ 0	locks=0 ]	(	[ displacement_control	"'none' if hou.pwd().evalParm('true_displacements')==1 else 'disconnectinput'" ] 	)
displacement	[ 0	locks=0 ]	(	""	)
maps_copnet	[ 8	locks=0 ]	(	../projection_maps	)
}

