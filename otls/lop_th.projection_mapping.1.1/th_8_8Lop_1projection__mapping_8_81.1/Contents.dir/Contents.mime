            disablewhen "{ opacity_primvar_control == block } { opacity_primvar_control == none } { opacity_primvar_control == disconnectinput }"
            parmtag { "parmvop" "1" }
            parmtag { "sidefx::shader_isparmuniform" "1" }
            parmtag { "usdvaluename" "inputs:opacity_primvar" }
            parmtag { "usdvaluetype" "string" }
        }
