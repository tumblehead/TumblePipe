      lefttype = extend
      righttype = extend
      flags = 0
      segment { length = 0 expr = ch(\"../distmetric\") }
    }
    channel rad {
      lefttype = extend
      righttype = extend
      default = 1.55
      flags = 0
      segment { length = 0 value = 1.55 1.55 expr = ch(\"../rad\") }
    }
    channel reverse {
      lefttype = extend
      righttype = extend
      default = 1
      flags = 0
      segment { length = 0 value = 1 1 expr = ch(\"../reverse\") }
    }
    channel ramp {
      lefttype = extend
      righttype = extend
      default = 2
      flags = 0
      segment { length = 0 value = 2 2 expr = ch(\"../ramp\") }
    }
    channel distattr {
      lefttype = extend
      righttype = extend
      defaultString = \"distancefromborder\"
      flags = 0
      segment { length = 0 expr = chs(\"../distattr\") }
    }
    channel ramp2pos {
      lefttype = extend
      righttype = extend
      flags = 0
      segment { length = 0 expr = ch(\"../ramp2pos\") }
    }
    channel ramp2value {
      lefttype = extend
      righttype = extend
      flags = 0
      segment { length = 0 expr = ch(\"../ramp2value\") }
    }
    channel ramp2interp {
      lefttype = extend
      righttype = extend
      default = 3
      flags = 0
      segment { length = 0 value = 3 3 expr = ch(\"../ramp2interp\") }
    }
  }

